---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
		<svg style="position:absolute;width:0;height:0">
			<filter id="frosted" primitiveUnits="objectBoundingBox">
				<feImage href="data:image/png;base64,... [truncated]
				<feGaussianBlur in="SourceGraphic" stdDeviation="0.02" result="blur"/>
				<feDisplacementMap id="disp" in="blur" in2="map" scale="1" xChannelSelector="R" yChannelSelector="G">
				</feDisplacementMap>
			</filter>
		</svg>
	</body>
</html>
<style is:global>
	:root {
		--bg-glass: rgba(255, 255, 255, 0.08);
		--border-glass: rgba(255, 255, 255, 0.6);
		--shadow-glass: rgba(0, 0, 0, 0.3);
	}
	html, body {
		margin: 0;
		padding: 0;
		width: 100%;
		height: 100%;
		background: transparent;
		overflow: hidden;
		font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
		color: white;
	}
	
	.liquid-glass {
		background: var(--bg-glass);
		border: 1px solid transparent;
		box-shadow: 0 0 0 1px var(--border-glass), 0 16px 32px var(--shadow-glass);
		backdrop-filter: url(#frosted);
		-webkit-backdrop-filter: url(#frosted);
		border-radius: 16px;
	}
</style>
